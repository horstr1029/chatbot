{
  "name": "mst-chatbot-desktop",
  "version": "1.0.0",
  "description": "MST Chatbot desktop client",
  "author": "MST",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "postinstall": "node scripts/generate-icons.js",
