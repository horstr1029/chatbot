# ─────────────────────────────────────────────────────────────────
# .env.prod.example
# Copy to .env.prod on the server and fill in real values.
# NEVER commit .env.prod to git.
# ─────────────────────────────────────────────────────────────────

# App
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# Database
POSTGRES_USER=chatbot
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=chatbot_prod
DATABASE_URL=postgresql://chatbot:CHANGE_ME_STRONG_PASSWORD@postgres:5432/chatbot_prod

# Redis
REDIS_URL=redis://redis:6379

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Ollama (optional — leave blank to disable)
OLLAMA_BASE_URL=

# OpenAI (for embeddings — optional if using Ollama nomic-embed-text)
OPENAI_API_KEY=sk-...

# Clerk Auth
CLERK_SECRET_KEY=sk_live_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_WEBHOOK_SECRET=whsec_...

# n8n
N8N_BASE_URL=http://n8n:5678
N8N_API_KEY=
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME
N8N_HOST=yourdomain.com
N8N_WEBHOOK_URL=https://yourdomain.com/

# Google Drive (for doc ingestion)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_KEY=

# Microsoft / SharePoint (for doc ingestion)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
