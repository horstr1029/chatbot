generator client {
  provider = "prisma-client-js"
  output   = "../apps/web/node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Department {
  id              String   @id @default(cuid())
  name            String
  systemPrompt    String?  @db.Text
  llmModel        String   @default("mistral:7b-instruct")
  embedModel      String   @default("nomic-embed-text")
  widgetToken     String?  @unique
  slackWebhookUrl String?
  approvalChain   Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  members                  UserDepartment[]
  documentSources          DocumentSource[]
  workflowRequests         WorkflowRequest[]
  announcements            Announcement[]
  formTemplates            FormTemplate[]
  reminders                Reminder[]
  crossDeptRequestsFrom    CrossDeptRequest[] @relation("crossFrom")
  crossDeptRequestsTo      CrossDeptRequest[] @relation("crossTo")
  workflowApprovalSteps    WorkflowApprovalStep[] @relation("stepApprovingDept")
}

model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  passwordHash       String
  name               String?
  isSuperAdmin          Boolean   @default(false)
  mustChangePassword    Boolean   @default(false)
  passwordResetToken    String?   @unique
  passwordResetExpires  DateTime?
  createdAt             DateTime  @default(now())
  deletedAt             DateTime?

  departments           UserDepartment[]
  workflowRequests      WorkflowRequest[]      @relation("requestedBy")
  workflowApprovals     WorkflowRequest[]      @relation("approvedBy")
  chatSessions          ChatSession[]
  reminders             Reminder[]
  approvalSteps         WorkflowApprovalStep[] @relation("stepApprovedBy")
  crossDeptRequests     CrossDeptRequest[]     @relation("crossRequester")
}

model UserDepartment {
  userId    String
  deptId    String
  role      DeptRole @default(MEMBER)
  user      User       @relation(fields: [userId], references: [id])
  dept      Department @relation(fields: [deptId], references: [id])
  createdAt DateTime   @default(now())

  @@id([userId, deptId])
}

enum DeptRole {
  MEMBER
  DEPT_ADMIN
}

model DocumentSource {
  id         String     @id @default(cuid())
  name       String
  sourceType SourceType
  sourceUrl  String?
  sourcePath String?
  deptId     String
  dept       Department @relation(fields: [deptId], references: [id])
  isGlobal   Boolean    @default(false)
  lastSynced DateTime?
  expiresAt  DateTime?
  createdAt  DateTime   @default(now())
  deletedAt  DateTime?
}

enum SourceType {
  GOOGLE_DRIVE
  SHAREPOINT
  LOCAL
}

model WorkflowRequest {
  id              String                @id @default(cuid())
  userMessage     String                @db.Text
  description     String                @db.Text
  n8nWorkflowId   String?
  n8nResumeUrl    String?
  status          WorkflowRequestStatus @default(PENDING)
  rejectionReason String?
  deptId          String
  dept            Department            @relation(fields: [deptId], references: [id])
  requestedById   String
  requestedBy     User                  @relation("requestedBy", fields: [requestedById], references: [id])
  approvedById    String?
  approvedBy      User?                 @relation("approvedBy", fields: [approvedById], references: [id])
  approvedAt      DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  approvalSteps WorkflowApprovalStep[]
}

enum WorkflowRequestStatus {
  PENDING
  APPROVED
  REJECTED
  EXECUTED
  FAILED
}

model ChatSession {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  deptId    String
  title     String?
  messages  Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SystemSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

model SavedMessage {
  id        String   @id @default(cuid())
  userId    String
  sessionId String
  messageId String
  content   String   @db.Text
  createdAt DateTime @default(now())

  @@unique([userId, messageId])
}

model Announcement {
  id          String     @id @default(cuid())
  deptId      String
  dept        Department @relation(fields: [deptId], references: [id])
  content     String     @db.Text
  active      Boolean    @default(true)
  createdById String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

model MessageFeedback {
  id         String   @id @default(cuid())
  messageId  String
  sessionId  String
  userId     String
  deptId     String
  rating     Int      // 1 = thumbs up, -1 = thumbs down
  createdAt  DateTime @default(now())

  @@unique([messageId, userId])
}

model FormTemplate {
  id        String     @id @default(cuid())
  deptId    String
  dept      Department @relation(fields: [deptId], references: [id])
  name      String
  fields    Json       // FormField[]
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model WorkflowApprovalStep {
  id              String             @id @default(cuid())
  workflowId      String
  workflow        WorkflowRequest    @relation(fields: [workflowId], references: [id])
  stepOrder       Int
  label           String
  approvingDeptId String
  approvingDept   Department         @relation("stepApprovingDept", fields: [approvingDeptId], references: [id])
  status          ApprovalStepStatus @default(PENDING)
  approvedById    String?
  approvedBy      User?              @relation("stepApprovedBy", fields: [approvedById], references: [id])
  approvedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime           @default(now())

  @@unique([workflowId, stepOrder])
}

enum ApprovalStepStatus {
  PENDING
  APPROVED
  REJECTED
}

model Reminder {
  id            String     @id @default(cuid())
  userId        String
  user          User       @relation(fields: [userId], references: [id])
  deptId        String
  dept          Department @relation(fields: [deptId], references: [id])
  title         String
  topic         String
  cronExpr      String
  scheduleLabel String
  active        Boolean    @default(true)
  lastSentAt    DateTime?
  nextRunAt     DateTime
  createdAt     DateTime   @default(now())
}

model CrossDeptRequest {
  id            String          @id @default(cuid())
  title         String
  description   String          @db.Text
  fromDeptId    String
  fromDept      Department      @relation("crossFrom", fields: [fromDeptId], references: [id])
  toDeptId      String
  toDept        Department      @relation("crossTo", fields: [toDeptId], references: [id])
  requestedById String
  requestedBy   User            @relation("crossRequester", fields: [requestedById], references: [id])
  status        CrossDeptStatus @default(OPEN)
  response      String?         @db.Text
  resolvedAt    DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

enum CrossDeptStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CANCELLED
}
